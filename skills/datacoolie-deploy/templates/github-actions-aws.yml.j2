name: "DataCoolie Deploy \u2014 AWS Glue"

on:
  push:
    branches: [main]
    paths:
      - "metadata/**"
      - "functions/**"
      - ".datacoolie/generated/run_aws_glue.py"

env:
  AWS_DEFAULT_REGION: {% raw %}${{ secrets.AWS_REGION }}{% endraw %}
  AWS_ACCESS_KEY_ID: {% raw %}${{ secrets.AWS_ACCESS_KEY_ID }}{% endraw %}
  AWS_SECRET_ACCESS_KEY: {% raw %}${{ secrets.AWS_SECRET_ACCESS_KEY }}{% endraw %}

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install datacoolie
      - run: python .agents/skills/datacoolie-deploy/scripts/preflight.py --platform aws --skip-auth

  package:
    needs: validate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install build
      - run: python .agents/skills/datacoolie-deploy/scripts/package.py --format wheel --output dist/
      - uses: actions/upload-artifact@v4
        with:
          name: functions-wheel
          path: dist/*.whl

  deploy:
    needs: package
    runs-on: ubuntu-latest
    environment: {{ env_name }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        with:
          name: functions-wheel
          path: dist/

      # Upload artifacts to S3 first (ScriptLocation must resolve before create/update-job)
      - name: Upload script to S3
        run: aws s3 cp .datacoolie/generated/run_aws_glue.py s3://{{ bucket }}/scripts/run_aws_glue.py

      - name: Upload functions wheel to S3
        run: aws s3 cp dist/ s3://{{ bucket }}/libs/ --recursive --exclude "*" --include "*.whl"

      - name: Sync metadata to S3
        run: aws s3 sync metadata/ s3://{{ bucket }}/metadata/

      # Create or update Glue job (artifacts already on S3)
      - name: Deploy Glue job
        run: |
          pip install datacoolie
          python .agents/skills/datacoolie-deploy/scripts/apply.py --platform aws --env {{ env_name }} --skip-upload
