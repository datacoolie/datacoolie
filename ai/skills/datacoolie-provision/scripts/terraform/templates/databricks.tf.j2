# Auto-generated by datacoolie-provision
# Platform: Databricks, Environment: {{ env }}

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    databricks = {
      source  = "databricks/databricks"
      version = "~> 1.40"
    }
  }
}

provider "databricks" {
  host  = var.databricks_host
  token = var.databricks_token
}

{% for resource in resources %}
{% if resource.resource_type.lower() == 'catalog' %}
resource "databricks_catalog" "{{ resource.name | replace('-', '_') }}" {
  name    = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"
  comment = "{{ resource.purpose }}"
}

{% elif resource.resource_type.lower() == 'schema' %}
resource "databricks_schema" "{{ resource.name | replace('-', '_') }}" {
  catalog_name = databricks_catalog.{{ resources[0].name | replace('-', '_') }}.name
  name         = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"
  comment      = "{{ resource.purpose }}"
}

{% elif resource.resource_type.lower() == 'volume' %}
resource "databricks_volume" "{{ resource.name | replace('-', '_') }}" {
  catalog_name = databricks_catalog.{{ resources[0].name | replace('-', '_') }}.name
  schema_name  = databricks_schema.{{ resource.name | replace('-', '_') }}.name
  name         = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"
  volume_type  = "MANAGED"
  comment      = "{{ resource.purpose }}"
}

{% endif %}
{% endfor %}
