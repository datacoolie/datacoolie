# Auto-generated by datacoolie-provision
# Platform: AWS, Environment: {{ env }}

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

{% for resource in resources %}
{% if resource.resource_type.lower() in ['s3', 's3 bucket', 's3_bucket'] %}
resource "aws_s3_bucket" "{{ resource.name | replace('-', '_') }}" {
  bucket = "{{ resource.name }}{% if env != 'prod' %}-{{ env }}{% endif %}"

  tags = {
    Environment = var.environment
    Purpose     = "{{ resource.purpose }}"
    ManagedBy   = "datacoolie-provision"
  }
}

{% elif resource.resource_type.lower() in ['glue database', 'glue_database'] %}
resource "aws_glue_catalog_database" "{{ resource.name | replace('-', '_') }}" {
  name = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"

  tags = {
    Environment = var.environment
    Purpose     = "{{ resource.purpose }}"
    ManagedBy   = "datacoolie-provision"
  }
}

{% elif resource.resource_type.lower() in ['iam role', 'iam_role'] %}
resource "aws_iam_role" "{{ resource.name | replace('-', '_') }}" {
  name = "{{ resource.name }}{% if env != 'prod' %}-{{ env }}{% endif %}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "glue.amazonaws.com"
        }
      }
    ]
  })

  tags = {
    Environment = var.environment
    Purpose     = "{{ resource.purpose }}"
    ManagedBy   = "datacoolie-provision"
  }
}

{% endif %}
{% endfor %}
