# Auto-generated by datacoolie-provision
# Platform: Fabric, Environment: {{ env }}
#
# NOTE: Fabric Terraform provider is community/preview.
# For production, prefer CLI mode (`fab` commands) or REST API.

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    fabric = {
      source  = "microsoft/fabric"
      version = "~> 0.1"
    }
  }
}

provider "fabric" {}

{% for resource in resources %}
{% if resource.resource_type.lower() == 'lakehouse' %}
resource "fabric_lakehouse" "{{ resource.name | replace('-', '_') }}" {
  display_name = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"
  workspace_id = var.workspace_id
}

{% elif resource.resource_type.lower() == 'warehouse' %}
resource "fabric_warehouse" "{{ resource.name | replace('-', '_') }}" {
  display_name = "{{ resource.name }}{% if env != 'prod' %}_{{ env }}{% endif %}"
  workspace_id = var.workspace_id
}

{% endif %}
{% endfor %}
