 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# DataCoolie Databricks Runner\n",
    "\n",
    "Reference used by datacoolie-deploy skill to understand Python API patterns.\n",
    "Platform: Databricks | Engine: spark"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "source": [
    "%pip install datacoolie /Volumes/my_catalog/bronze/files/libraries/functions*.whl --force-reinstall"
   ],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "source": [
    "dbutils.library.restartPython()  # type: ignore[name-defined]"
   ],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "source": [
    "from datacoolie.core.models import DataCoolieRunConfig\n",
    "from datacoolie.engines.spark_engine import SparkEngine\n",
    "from datacoolie.metadata.file_provider import FileProvider\n",
    "from datacoolie.orchestration.driver import DataCoolieDriver\n",
    "from datacoolie.platforms.databricks_platform import DatabricksPlatform\n",
    "\n",
    "VOLUME_ROOT = \"/Volumes/my_catalog/bronze/files\"\n",
    "METADATA_PATH = f\"{VOLUME_ROOT}/metadata/use_cases.json\"\n",
    "BASE_LOG_PATH = f\"{VOLUME_ROOT}/logs/datacoolie\"\n",
    "STAGE = \"\"  # empty = run all stages\n",
    "\n",
    "platform = DatabricksPlatform()\n",
    "engine = SparkEngine(spark, platform=platform)  # spark provided by Databricks runtime\n",
    "metadata = FileProvider(config_path=METADATA_PATH, platform=platform)\n",
    "run_config = DataCoolieRunConfig(max_workers=4)\n",
    "\n",
    "with DataCoolieDriver(\n",
    "    engine=engine,\n",
    "    metadata_provider=metadata,\n",
    "    base_log_path=BASE_LOG_PATH,\n",
    "    config=run_config,\n",
    ") as driver:\n",
    "    result = driver.run(stage=STAGE if STAGE else None)\n",
    "\n",
    "print({\"total\": result.total, \"succeeded\": result.succeeded, \"failed\": result.failed, \"skipped\": result.skipped})"
   ],
   "execution_count": null
  }
 ],
