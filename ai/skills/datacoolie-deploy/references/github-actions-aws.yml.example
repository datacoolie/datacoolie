# Reference example — GitHub Actions CI/CD for AWS Glue
# Reference used by datacoolie-deploy skill to understand CI/CD patterns.

name: "DataCoolie Deploy — AWS Glue"

on:
  push:
    branches: [main]
    paths:
      - "{project_name}_dcws/metadata/**"
      - "{project_name}_dcws/functions/**"
      - "{project_name}_dcws/generated/run_aws_glue.py"

env:
  AWS_DEFAULT_REGION: ${{ secrets.AWS_REGION }}
  AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
  AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install datacoolie
      - run: python -c "import datacoolie; print('datacoolie', datacoolie.__version__)"

  package:
    needs: validate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install build
      - run: cd {project_name}_dcws/functions && pip wheel --no-deps -w ../generated/dist . && cd ../..
      - uses: actions/upload-artifact@v4
        with:
          name: functions-wheel
          path: {project_name}_dcws/generated/dist/*.whl

  deploy:
    needs: package
    runs-on: ubuntu-latest
    environment: prod
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        with:
          name: functions-wheel
          path: {project_name}_dcws/generated/dist/

      # Upload artifacts to S3 first (ScriptLocation must resolve before create/update-job)
      - name: Upload runner script to S3
        run: aws s3 cp {project_name}_dcws/generated/run_aws_glue.py s3://my-project-bucket/scripts/run_aws_glue.py

      - name: Upload functions wheel to S3
        run: aws s3 cp {project_name}_dcws/generated/dist/ s3://my-project-bucket/libs/ --recursive --exclude "*" --include "*.whl"

      - name: Sync metadata to S3
        run: aws s3 sync {project_name}_dcws/metadata/ s3://my-project-bucket/metadata/

      - name: Create or update Glue job
        run: |
          pip install datacoolie
          # Use current AWS CLI to create or update the Glue job referencing the uploaded script
