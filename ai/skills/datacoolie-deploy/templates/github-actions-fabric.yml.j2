name: "DataCoolie Deploy \u2014 Fabric"

on:
  push:
    branches: [main]
    paths:
      - "metadata/**"
      - "functions/**"

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install datacoolie
      - run: python .agents/skills/datacoolie-deploy/scripts/preflight.py --platform fabric --skip-auth

  package:
    needs: validate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install build
      - run: python .agents/skills/datacoolie-deploy/scripts/package.py --format wheel --output dist/
      - uses: actions/upload-artifact@v4
        with:
          name: functions-wheel
          path: dist/*.whl

  deploy:
    needs: package
    runs-on: ubuntu-latest
    environment: {{ env_name }}
    env:
      FABRIC_CLIENT_ID: {% raw %}${{ secrets.FABRIC_CLIENT_ID }}{% endraw %}
      FABRIC_CLIENT_SECRET: {% raw %}${{ secrets.FABRIC_CLIENT_SECRET }}{% endraw %}
      FABRIC_TENANT_ID: {% raw %}${{ secrets.FABRIC_TENANT_ID }}{% endraw %}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        with:
          name: functions-wheel
          path: dist/
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install ms-fabric-cli datacoolie jinja2
      - name: Authenticate Fabric CLI
        run: fab auth login -u $FABRIC_CLIENT_ID -p $FABRIC_CLIENT_SECRET --tenant $FABRIC_TENANT_ID
      - name: Deploy to Fabric
        run: python .agents/skills/datacoolie-deploy/scripts/apply.py --platform fabric --env {{ env_name }}
